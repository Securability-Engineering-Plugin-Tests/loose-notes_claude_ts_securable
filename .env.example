# --------------------------------------------------------------------------
# LooseNotes — Environment configuration
# Copy to .env.local for local development. NEVER commit real secrets.
# In production, set these in Vercel Project Settings → Environment Variables.
# --------------------------------------------------------------------------

# Required: 256-bit random secret for signing session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=replace-me-with-32-bytes-of-base64url

# Required: 256-bit random secret for password reset tokens.
SESSION_RESET_SECRET=replace-me-with-32-bytes-of-base64url

# Required: 256-bit random key for the optional AES-GCM utility.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
APP_DATA_KEY=replace-me-with-32-bytes-of-base64url

# Cookie options (Production: leave SECURE=true; Local HTTP only: set to false)
COOKIE_SECURE=true

# Allowed Origin for CSRF/Origin checks (comma separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=info

# Initial bootstrap admin (created on first cold start ONLY when both vars are set
# AND no admin exists yet). The password is consumed once and never persisted to
# disk; rotate immediately after first login. Leave UNSET in production once you
# have a real admin account.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
